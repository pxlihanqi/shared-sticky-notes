{
  "name": "shared-sticky-notes",
  "version": "1.5.6",
  "description": "共享便签 - 跨平台桌面便签应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "server": "node server.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.sharedstickynotes.app",
    "productName": "共享便签",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "public/**/*",
      "icon.png",
      "iconTemplate.png"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "identity": null
    },
    "win": {
      "icon": "dist/.icon-ico/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": "ia32"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "共享便签",
      "menuCategory": true
    }
  },
  "keywords": [],
  "author": "共享便签",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "lowdb": "^1.0.0",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8"
  }
}
